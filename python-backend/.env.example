# Python Backend — Environment Variables
# Copy this to .env and fill in your values.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=production       # Set to "development" to enable /api/docs + verbose errors
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase pooler connection string (use port 6543 for serverless/edge)
# Example: postgresql+asyncpg://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/coded_chapter

# ── Supabase Auth ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Found in: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-signing-secret

# ── Admin ─────────────────────────────────────────────────────────────────────
# Only this email address can create, edit, or delete posts
ADMIN_EMAIL=admin@example.com

# ── Substack Integration ──────────────────────────────────────────────────────
# Set to false when you are ready to use your own PostgreSQL database
# When false: all post reads go to the database, not Substack
USE_SUBSTACK=true
SUBSTACK_FEED_URL=https://codedchapter.substack.com/feed
SUBSTACK_CACHE_TTL_SECONDS=300   # 5 minutes

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://codedchapter.vercel.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PUBLIC=100/minute
RATE_LIMIT_AUTH=30/minute
RATE_LIMIT_STRICT=10/minute
