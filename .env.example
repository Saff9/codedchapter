# =============================================================================
# Coded Chapter — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the real .env file to git.
# =============================================================================

# =============================================================================
# Database
# Use the Supabase connection pooler URL (port 6543) for serverless/Vercel.
# Use the direct URL (port 5432) for Render or long-lived connections.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
# =============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/coded_chapter

# =============================================================================
# Supabase (backend — used to verify JWTs and connect to the database)
# Find these in: Supabase Dashboard > Project Settings > API
# =============================================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# JWT Secret: Supabase Dashboard > Project Settings > API > JWT Secret
# This is used to verify that login tokens are real and haven't been tampered with.
SUPABASE_JWT_SECRET=your-supabase-jwt-signing-secret

# =============================================================================
# Supabase (frontend — baked into the JS bundle at build time)
# These are safe to be public. Do NOT put the JWT secret here.
# Set these in Vercel's environment variables dashboard before deploying.
# =============================================================================
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# =============================================================================
# Admin
# Only the account with this email address can write and publish posts.
# Both values should be the same email. VITE_ prefix exposes it to the frontend
# so the UI can show/hide the write button.
# =============================================================================
ADMIN_EMAIL=your@email.com
VITE_ADMIN_EMAIL=your@email.com

# =============================================================================
# Upstash Redis (optional but recommended in production)
# Used for rate limiting across multiple server instances.
# Without this, rate limits are per-instance and reset on restart.
# Free tier on https://console.upstash.com is enough to start.
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# =============================================================================
# Deployment
# FRONTEND_URL: your Vercel domain — used for CORS so the backend only accepts
#               requests from your real frontend.
# VITE_API_URL: your Render backend URL — used by the frontend to know where
#               to send API requests. Leave blank for local dev (proxied by Vite).
# PORT: the port the Express server listens on. Default is 5000.
# =============================================================================
FRONTEND_URL=https://your-domain.vercel.app
VITE_API_URL=https://your-backend.onrender.com
PORT=5000
